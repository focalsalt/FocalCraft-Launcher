{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focal Craft Launcher",
  "version": "20.26.1",
  "identifier": "com.focal.mc-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focal Craft Launcher",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://* http://* data:; connect-src 'self' https://* http://*; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFNDVGNEEwMTlFODQ3RTQKUldUa1IrZ1pvUFJGcms2SkNmMmpMbVc3TngwS2xqdTY3SGh0ZlpHSkE5OUlKaG5BZU0ybmpJVDQK",
      "endpoints": [
        "https://raw.githubusercontent.com/focalsalt/FocalCraft-Launcher/refs/heads/main/updater.json"
      ]
    }
  }
}